{
  "name": "wukong-bot",
  "version": "2.1.0",
  "description": "飞书机器人 + Claude Code CLI 系统 (参考 deer-flow 架构)",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "gateway": "bun run src/gateway.ts",
    "worker": "bun run src/worker.ts",
    "build": "bun build src/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.34.1",
    "hono": "^4.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.0",
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "module": "src/index.ts",
  "private": true
}
