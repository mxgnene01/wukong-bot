# 飞书应用配置
APP_ID=cli_xxxxxx
APP_SECRET=xxxxxxxxxx

# 事件源配置: websocket (长连接，推荐) 或 webhook
EVENT_SOURCE=webhook

# Claude Code CLI 配置
CLAUDE_CODE_PATH=claude
# 工作目录 (绝对路径推荐，例如 /Users/username/.wukong/workspace)
WORK_DIR=./workspace

# 服务配置
PORT=3000

# 心跳配置
HEARTBEAT_INTERVAL=30000
TASK_TIMEOUT=1800000

# PM2 进程名称
PM2_NAME=wukong-bot

# 日志配置: debug, log, info, warn, error
LOG_LEVEL=info
LOG_ENABLE_FILE=true
LOG_ENABLE_CONSOLE=true
